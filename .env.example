# Kiso environment — copy to .env and fill in real values:
#   cp .env.example .env
#
# Used by:
#   docker compose up        — auto-loaded via env_file in docker-compose.yml
#   source .env              — load into current shell for local dev / live tests
#
# Format: KEY=VALUE (no 'export' — compatible with both Docker and bash source)

# LLM API key (required for LLM calls)
# Get yours at https://openrouter.ai/keys
KISO_LLM_API_KEY=

# ── Optional: credentials for live MCP tests ────────────────────────────────
# Each key is read by tests/live/test_mcp_auth_servers.py and gates a
# specific live test. Leave blank to skip.

# https://api.search.brave.com/app/keys
BRAVE_API_KEY=

# https://github.com/settings/tokens — scope: public_repo (read-only is enough)
GITHUB_PERSONAL_ACCESS_TOKEN=

# https://console.cloud.google.com/ → enable "Maps Grounding Lite" + billing
GOOGLE_MAPS_API_KEY=
