FROM python:3.12-slim

RUN apt-get update -qq && \
    apt-get install -y --no-install-recommends git curl openssh-client && \
    rm -rf /var/lib/apt/lists/*

COPY --from=ghcr.io/astral-sh/uv:latest /uv /usr/local/bin/uv

WORKDIR /opt/kiso

# Install dependencies — cached layer invalidates ONLY when uv.lock changes.
COPY uv.lock ./
RUN printf '[project]\nname = "kiso"\nversion = "0.0.0"\nrequires-python = ">=3.11"\n' > pyproject.toml && \
    uv sync --frozen --no-install-project && \
    rm pyproject.toml

# Copy source + tests
COPY pyproject.toml ./
COPY kiso/ kiso/
COPY cli/ cli/
COPY tests/ tests/
RUN uv sync --frozen

CMD ["uv", "run", "pytest", "tests/", "-q"]
